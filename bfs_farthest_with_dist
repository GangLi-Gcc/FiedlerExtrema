# -*- coding: utf-8 -*-
"""
Function F: Output all farthest pairs (x, y) realizing the diameter of the tree T.

Input:
- T: an undirected, unweighted tree using networkx.Graph

Output:
- A tuple (diam, pairs)
  - diam: diameter length (int)
  - pairs: a list of tuples [(x1, y1), (x2, y2), ...] such that d(xi, yi) == diam
  - If tree is empty: diam = 0, pairs = []
  - If tree has single node: diam = 0, pairs = [(node, node)]

Algorithm outline:
1) BFS from an arbitrary node to get farthest node u.
2) BFS from u to get farthest node v and diameter diam.
   Also collect dist_u: distances from u.
   And collect dist_v: distances from v (via second BFS).
3) Build sets:
   A = { x | dist_u[x] == diam }
   B = { y | dist_v[y] == diam }
   Note: Both A and B are based on known diameter endpoints.
4) For all x in A, y in B, if d(x, y) == diam, output (x, y).
   To avoid duplicate outputs, we only output ordered pairs with x <= y.
5) Other edge cases as mentioned earlier.

Feel free to modify the output format to your preferred structure (e.g., sorted lexicographically or output as DataFrame).

Below is the modified implementation code:
"""

import networkx as nx
from typing import Optional, Tuple, List, Dict, Set
from collections import deque

def bfs_farthest_with_dist(G: nx.Graph, start) -> Tuple[object, int, Dict[object, int], Dict[object, object]]:
    """
    Perform BFS from start in graph G.
    Returns:
      far_node: a farthest node from start
      maxd: distance to that farthest node
      dist: dict node -> distance from start
      parent: dict node -> predecessor in BFS tree
    """
    dist = {start: 0}
    parent = {start: None}
    q = deque([start])
    far_node = start
    maxd = 0
    visited = set([start])

    while q:
        u = q.popleft()
        du = dist[u]
        if du > maxd:
            maxd = du
            far_node = u
        for w in G.neighbors(u):
            if w not in visited:
                visited.add(w)
                dist[w] = du + 1
                parent[w] = u
                q.append(w)
    return far_node, maxd, dist, parent

def diameter_and_all_pairs(T: nx.Graph) -> Tuple[int, List[Tuple[object, object]]]:
    """
    Compute diameter and all farthest pairs (x, y) such that d(x, y) == diameter.
    Returns:
      (diameter, list_of_pairs)
    """
    if T is None:
        raise ValueError("Input graph is None")
    n = T.number_of_nodes()
    if n == 0:
        return 0, []
    if n == 1:
        node = next(iter(T.nodes()))
        return 0, [(node, node)]

    # Step 1: pick an arbitrary node
    start = next(iter(T.nodes()))

    # Step 2: BFS from start to find farthest u
    u, _, dist_from_start, _ = bfs_farthest_with_dist(T, start)

    # Step 3: BFS from u to find farthest v and diameter
    v, diam, dist_u, _ = bfs_farthest_with_dist(T, u)

    # Step 4: BFS from v to get dist_v
    v_end, diam_check, dist_v, _ = bfs_farthest_with_dist(T, v)
    # diam_check should equal diam; we keep diam as computed from u side.

    # Collect A and B
    A = {x for x, d in dist_u.items() if d == diam}
    B = {y for y, d in dist_v.items() if d == diam}

    # If there is no cross-pair, ensure we handle gracefully
    if not A or not B:
        # Fallback: return the single known pair (u, v)
        return diam, [(u, v)]

    # Precompute distances from all nodes in A (one BFS per a in A)
    dist_from_A = {}
    for a in A:
        # BFS from a
        _, _, dist_a, _ = bfs_farthest_with_dist(T, a)
        dist_from_A[a] = dist_a  # map node -> distance from a

    # Now, check pairs (a, b) with a in A, b in B
    pairs_set: Set[Tuple[object, object]] = set()
    for a in A:
        dist_a = dist_from_A[a]
        for b in B:
            dab = dist_a.get(b)
            if dab is None:
                continue
            if dab == diam:
                # canonical ordered pair to avoid duplicates
                x, y = (a, b) if str(a) <= str(b) else (b, a)
                pairs_set.add((x, y))

    # Convert to sorted list for deterministic output
    pairs_list = sorted(list(pairs_set), key=lambda t: (str(t[0]), str(t[1])))

    return diam, pairs_list

# Public API wrapper
def F(T: nx.Graph) -> Tuple[int, List[Tuple[Optional[object], Optional[object]]]]:
    """
    Public function: F(T) -> (diameter, all_farthest_pairs)
    - T: networkx.Graph representing a tree (undirected, unweighted)
    Returns:
      (diameter, list_of_pairs)
    """
    diam, pairs = diameter_and_all_pairs(T)
    return diam, pairs

# Example usage (simple self-test)
if __name__ == "__main__":
    # Construct an example tree
    G = nx.Graph()
    edges = [
        (0, 1),
        (1, 2),
        (1, 3),
        (3, 4),
        (4, 5)
    ]
    G.add_edges_from(edges)

    diam, all_pairs = F(G)
    print("Diameter:", diam)
    print("All farthest pairs:")
    for p in all_pairs:
        print(p)


