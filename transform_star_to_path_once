# -*- coding: utf-8 -*-
"""
Tree-to-tree transformation: convert star-like (center with multiple leaf neighbors) 
into a path-like structure for each center, while keeping vertex labels unchanged.

Algorithm (as described):
- Identify centers u in T1: deg(u) >= 2 and among neighbors there are at least two leaves (deg == 1).
- For each such center, collect its leaf neighbors leaves = sorted([v for v in N(u) if deg(v) == 1])
  (sorted by node label to ensure deterministic order).
- In T2 (a copy of T1), remove edges (u, leaf) for all leaf in leaves.
- Then add edges to form a path across [u] + leaves in this order:
  - add edge (u, leaves[0])
  - for i in range(len(leaves) - 1): add edge (leaves[i], leaves[i+1])
- This transforms the star around u into a path u - leaves[0] - leaves[1] - ... - leaves[m-1].

Notes:
- The transformation is done in a single pass based on T1's structure; multiple centers are processed independently.
- If a center has exactly 2 leaves, the transformation yields a path: u - leaf1 - leaf2.
- Other parts of the tree remain unchanged.

Usage:
- Build T1 as a networkx.Graph() with edges (u, v).
- Call F(T1) to obtain T2 (a new graph).

"""

import networkx as nx
from typing import Dict, List, Set

def transform_star_to_path_once(T1: nx.Graph) -> nx.Graph:
    """
    Perform the star-to-path transformation on the given tree T1.
    Returns a new graph T2 with the transformation applied.

    Preconditions:
    - T1 is a tree (connected, acyclic)
    - Node labels are hashable and unique within T1

    Postconditions:
    - T2 is a tree (assuming T1 is a tree and transformation rules are well-defined)
    - Vertex labels are unchanged
    - For every center u in T1 with >=2 leaf neighbors, the set {u} ∪ leaves becomes a path in T2
    """
    if T1 is None:
        raise ValueError("T1 must be a valid networkx.Graph")

    if not isinstance(T1, nx.Graph):
        raise TypeError("T1 must be a networkx Graph")

    # Quick sanity: ensure T1 is a tree (optional but helpful)
    # A tree on n nodes has exactly n-1 edges and is connected.
    n = T1.number_of_nodes()
    m = T1.number_of_edges()
    if m != n - 1:
        # Not strictly necessary to fail, but we warn
        # We proceed anyway; user should pass a tree
        pass

    # Copy the original graph to T2
    T2 = T1.copy()

    # Helpers to know degrees in T1 (the reference structure)
    deg_T1: Dict = dict(T1.degree())

    # Determine centers in T1: nodes with at least two leaf neighbors
    centers: Dict = {}  # center_node -> List[leaf_neighbors]
    leaves_to_center: Dict = {}  # optional: map leaf -> center (not strictly needed)

    for u in T1.nodes():
        du = deg_T1[u]
        if du <= 1:
            continue  # skip leaves

        # Collect leaf neighbors of u in T1
        neigh = list(T1.neighbors(u))
        leaf_neighbors = [v for v in neigh if deg_T1[v] == 1]

        if len(leaf_neighbors) >= 2:
            # Deterministic order: sort by node label
            leaf_neighbors_sorted = sorted(leaf_neighbors, key=lambda x: str(x))
            centers[u] = leaf_neighbors_sorted
            for v in leaf_neighbors_sorted:
                leaves_to_center[v] = u  # optional

    # If no centers, return T2 as a copy (no changes)
    if not centers:
        return T2

    # For deterministic behavior across sets, process centers in sorted order of center id
    # Sorting by their string representation to handle mixed types gracefully
    for u in sorted(centers.keys(), key=lambda x: str(x)):
        leaves = centers[u]  # already sorted list of leaves in T1

        # In T2, remove edges (u, leaf) for all leaf in leaves
        for leaf in leaves:
            if T2.has_edge(u, leaf):
                T2.remove_edge(u, leaf)

        # Now add edges to form path: u - leaves[0] - leaves[1] - ... - leaves[-1]
        # First, connect u with the first leaf
        if leaves:
            v0 = leaves[0]
            if not T2.has_edge(u, v0):
                T2.add_edge(u, v0)

            # Then connect consecutive leaves to form a path
            for i in range(len(leaves) - 1):
                a = leaves[i]
                b = leaves[i + 1]
                if not T2.has_edge(a, b):
                    T2.add_edge(a, b)

        # Note: If a center u had additional non-leaf neighbors (other than the leaves),
        # they remain untouched in T2 (as per the specification).

    return T2
