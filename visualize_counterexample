def get_subtree(G, root, exclude_nodes=None):
    """
    Get the independent subtree rooted at root (strictly excluding nodes from another tree)
    Args:
        G: original graph
        root: subtree root node
        exclude_nodes: set of nodes to be excluded
    Returns:
        nx.Graph: a completely independent subtree
    """
    if exclude_nodes is None:
        exclude_nodes = set()
    
    subtree = nx.Graph()
    visited = set([root])
    queue = [root]
    
    while queue:
        node = queue.pop(0)
        for neighbor in G.neighbors(node):
            if neighbor not in visited and neighbor not in exclude_nodes:
                visited.add(neighbor)
                subtree.add_edge(node, neighbor)
                queue.append(neighbor)
    return subtree

def compute_tree_layout(tree, root, direction):
    """
    Compute coordinates for the tree (strict direction control)
    direction: 
      'up'   - grow upward (y as positive integers)
      'down' - grow downward (y as negative integers)
    """
    # Compute node depths
    depths = {root: 0}
    queue = [(root, 0)]
    while queue:
        node, depth = queue.pop(0)
        for neighbor in tree.neighbors(node):
            if neighbor not in depths:
                depths[neighbor] = depth + 1
                queue.append((neighbor, depth + 1))
    
    # Compute coordinates
    pos = {}
    for node, depth in depths.items():
        # horizontal coordinate (centered within the layer)
        siblings = [n for n in depths if depths[n] == depth]
        x = (siblings.index(node) - (len(siblings)-1)/2) * 2
        
        # vertical coordinate (core modification: strictly integers and directional separation)
        if direction == 'up':
            y = depth + 1  # ensure positive integers starting from 1
        else:
            y = -(depth + 1)  # ensure negative integers starting from -1
            
        pos[node] = (x, y)
    return pos

def dual_bfs_layout(G, u, v):
    """Generate dual-BFS layout (final direction corrected)"""
    # Get two independent subtrees
    subtree_u = get_subtree(G, root=u, exclude_nodes={v})
    subtree_v = get_subtree(G, root=v, exclude_nodes={u})
    
    # Compute layouts (opposite directions)
    pos_u = compute_tree_layout(subtree_u, u, 'up')    # u-tree up (y positive)
    pos_v = compute_tree_layout(subtree_v, v, 'down')   # v-tree down (y negative)
    
    # Merge layouts (align at the v node)
    if v in pos_u:
        # Get v's coordinates in the u-tree
        x_v_u, y_v_u = pos_u[v]
        
        # Compute offset for v-tree to align v at the same position
        x_v_v, y_v_v = pos_v.get(v, (0, 0))
        delta_x = x_v_u - x_v_v
        delta_y = y_v_u - y_v_v
        
        # Adjust coordinates of v-tree
        adjusted_pos_v = {
            node: (x + delta_x, y + delta_y)
            for node, (x, y) in pos_v.items()
        }
        
        # Merge (prefer coordinates from u-tree for overlap)
        pos = {**adjusted_pos_v, **pos_u}
    else:
        pos = pos_u
    
    return pos

def compute_fiedler_vector(G):
    """Compute the Fiedler vector (strictly by node order)"""
    nodes = sorted(G.nodes())
    try:
        L = nx.laplacian_matrix(G, nodelist=nodes).astype(float)
        eigenvalues, eigenvectors = eigsh(L, k=2, which='SM')
        if len(eigenvalues) >= 2:
            return eigenvectors[:, 1], nodes
    except:
        return np.zeros(len(nodes)), nodes

def visualize_dual_bfs(G, u, v):
