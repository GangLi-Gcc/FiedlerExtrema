        n: f"{n}\n{fiedler_vector[node_index[n]]:.3f}"
        for n in nodes
    }
    
    # Compute layouts
    pos1 = dual_bfs_layout(G, u, v)
    pos2 = dual_bfs_layout(G, v, u)
