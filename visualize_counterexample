import networkx as nx
from collections import deque
from typing import Tuple, List, Set

def tree_diameter_endpoints(G: nx.Graph) -> Tuple[Set[int], int]:
    """
    Given an undirected connected tree G (networkx.Graph), return
    - farthest_nodes: the set of farthest nodes (diameter endpoints)
    - diameter: the diameter length (the maximum shortest-path length between endpoints)
    
    Requirements:
    - G must be an undirected, connected tree (with n-1 edges, where n is the number of nodes).
    - Node labels are assumed to be integers, starting from 0 or any set of integers.
    """
    if G.number_of_nodes() == 0:
        return set(), 0

    def bfs(start_node: int) -> Tuple[dict, int, int]:
        """
        Perform BFS from the start node `start_node`, returning (dist, far_node, max_dist)
        dist: dictionary (node -> distance)
        far_node: one of the farthest nodes from start_node (if multiple, returns one arbitrarily)
        max_dist: the maximum distance
        """
        dist = {start_node: 0}
        q = deque([start_node])
        far_node = start_node
        max_dist = 0
        while q:
            u = q.popleft()
            du = dist[u]
            if du > max_dist:
                max_dist = du
                far_node = u
            for v in G.neighbors(u):
                if v not in dist:
                    dist[v] = du + 1
                    q.append(v)
        return dist, far_node, max_dist

    # 1) From an arbitrary node, take one farthest node u
    any_node = next(iter(G.nodes))
    dist0, u, _ = bfs(any_node)

    # 2) From u, obtain distance vector dist_u, maximum distance dmax, and construct set S1
    dist_u, v, dmax = bfs(u)
    S1 = {node for node, d in dist_u.items() if d == dmax}
    if not S1:
        return set(), 0

    # 3) From an arbitrary node w in S1, obtain dist_w, and collect nodes at distance dmax as S2
    w = next(iter(S1))
    dist_w, _, _ = bfs(w)
    S2 = {node for node, d in dist_w.items() if d == dmax}

    farthest_nodes = S1.union(S2)
    return farthest_nodes, dmax
